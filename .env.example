# API Key 為選填；未設定時仍會使用免費公開 RSS 來源。
#
# NewsAPI API Key
# 取得方式：https://newsapi.org/register
# 複製本檔為 .env 後填入金鑰，例如：
# VITE_NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_NEWS_API_KEY=

# GNews API Key (https://gnews.io)
VITE_GNEWS_API_KEY=

# MediaStack API Key (https://mediastack.com)
VITE_MEDIASTACK_API_KEY=
